# Runtime/serverless queries use the pooled Neon endpoint.
DATABASE_URL="postgresql://atride:atride@localhost:5432/atride"

# Prisma migrations use a direct endpoint to avoid transaction-pooler limitations.
DIRECT_URL="postgresql://atride:atride@localhost:5432/atride"

# At least 32 random characters; used to protect OTP challenges and sessions.
AUTH_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Use "mock" locally or "ses" for real email delivery.
# Reserved *.test identities always use the on-screen mock in non-production environments.
EMAIL_PROVIDER="mock"
SMS_PROVIDER="disabled"

# Required when EMAIL_PROVIDER="ses". SES identity and sandbox status are region-specific.
AWS_REGION="ap-south-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional when temporary AWS credentials are used.
AWS_SESSION_TOKEN=""
SES_FROM_EMAIL="noreply@atride.in"
SES_FROM_NAME="@Ride"
# Optional and visible to message recipients; omit for no-reply OTP email.
SES_REPLY_TO_EMAIL=""

# Google OpenID Connect. APP_URL must exactly match a registered callback origin.
APP_URL="http://localhost:3000"

# Protects the durable notification-outbox retry endpoint.
CRON_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Firebase is used only for one-time phone ownership verification, not AtRide sessions.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Cloudinary signed uploads. API secret is server-only.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER_PREFIX="atride/development"

# Optional server-side Ride Studio assistant. The key is never exposed to the browser.
# Keep disabled when no provider budget/quota should be consumed; the copy/open-Gemini fallback still works.
AI_ASSIST_ENABLED="false"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
