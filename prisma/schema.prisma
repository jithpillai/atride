  lockedAt          DateTime?                @map("locked_at") @db.Timestamptz(3)
  deliveredAt       DateTime?                @map("delivered_at") @db.Timestamptz(3)
  providerMessageId String?                  @map("provider_message_id") @db.VarChar(240)
  providerDeliveryStatus EmailDeliveryStatus @default(NOT_TRACKED) @map("provider_delivery_status")
  providerStatusUpdatedAt DateTime?           @map("provider_status_updated_at") @db.Timestamptz(3)
  lastError         String?                  @map("last_error") @db.Text
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  community      Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  booking        RideBooking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingPayment BookingPayment? @relation(fields: [bookingPaymentId], references: [id], onDelete: Cascade)
  recipient      User            @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([status, availableAt, createdAt])
  @@index([providerMessageId])
  @@index([providerDeliveryStatus, providerStatusUpdatedAt])
  @@index([communityId, eventType, createdAt])
  @@index([bookingPaymentId, eventType])
  @@index([bookingId, eventType])
  @@map("notification_outbox_events")
}

model EmailProviderEvent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider          String   @db.VarChar(24)
  providerEventId   String   @unique @map("provider_event_id") @db.VarChar(240)
  providerMessageId String?  @map("provider_message_id") @db.VarChar(240)
  eventType         String   @map("event_type") @db.VarChar(40)
  occurredAt        DateTime @map("occurred_at") @db.Timestamptz(3)
  processedAt       DateTime @default(now()) @map("processed_at") @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([providerMessageId, occurredAt])
  @@index([createdAt])
  @@map("email_provider_events")
}

model EmailSuppression {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  normalizedEmail String   @unique @map("normalized_email") @db.VarChar(320)
  reason          String   @db.VarChar(40)
  provider        String   @db.VarChar(24)
  providerEventId String   @map("provider_event_id") @db.VarChar(240)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([reason, createdAt])
  @@map("email_suppressions")
}

model NotificationInboxItem {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventKey        String                @unique @map("event_key") @db.VarChar(240)
  eventType       NotificationEventType @map("event_type")
  communityId     String                @map("community_id") @db.Uuid
  bookingId       String?               @map("booking_id") @db.Uuid
  recipientUserId String                @map("recipient_user_id") @db.Uuid
  title           String                @db.VarChar(180)
  body            String                @db.VarChar(500)
  actionUrl       String?               @map("action_url") @db.VarChar(500)
  readAt          DateTime?             @map("read_at") @db.Timestamptz(3)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  community Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  booking   RideBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  recipient User         @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt, createdAt])
  @@index([communityId, createdAt])
  @@map("notification_inbox_items")
}

model UserNotificationPreference {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String   @unique @map("user_id") @db.Uuid
  emailRideReminders        Boolean  @default(true) @map("email_ride_reminders")
  emailRoutineAnnouncements Boolean  @default(true) @map("email_routine_announcements")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}
