generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommunityStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum DirectoryVisibility {
  LISTED
  UNLISTED
}

enum GuildHallAccess {
  PUBLIC
  VERIFIED_USERS
  GUILD_MEMBERS
  INVITE_ONLY
}

enum SearchIndexing {
  INDEXABLE
  NOINDEX
}

enum RideVisibility {
  PUBLIC
  VERIFIED_USERS
  GUILD_MEMBERS
  INVITE_ONLY
}

enum RideStatus {
  DRAFT
  PUBLISHED
  CLOSED
  POSTPONED
  CANCELLED
  COMPLETED
}

enum VehicleType {
  BIKE
  CAR
  SUV
  JEEP
  OTHER
}

enum RideDifficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum RidePackageItemType {
  INCLUSION
  EXCLUSION
  ADD_ON
  MEAL
  ACTIVITY
}

enum RidePolicyType {
  SAFETY
  PAYMENT
  CANCELLATION
  REPLACEMENT
  PROPERTY_CONDUCT
  WAIVER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ContactType {
  EMAIL
  PHONE
}

enum ExternalIdentityProvider {
  GOOGLE
}

enum PhoneVerificationProvider {
  FIREBASE
}

enum PhoneVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum MediaPurpose {
  USER_AVATAR
  GUILD_LOGO
  GUILD_COVER
  GUILD_GALLERY
  RIDE_COVER
  RIDE_GALLERY
  PAYMENT_PROOF
}

enum MediaAccess {
  PUBLIC
  AUTHENTICATED
  PRIVATE
}

enum OtpPurpose {
  SIGN_IN
  ACCOUNT_RECOVERY
  CONTACT_VERIFICATION
}

enum PlatformRole {
  PLATFORM_ADMIN
  SUPPORT
  MODERATOR
}

enum CommunityMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LEFT
}

enum CommunityRole {
  OWNER
  ADMIN
  RIDE_MANAGER
  FINANCE
  MEMBER_MANAGER
}

enum CommunityInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum RideStaffRole {
  LEAD_CAPTAIN
  CAPTAIN
  VICE_CAPTAIN
  SWEEP
  MARSHAL
  VOLUNTEER
}

enum BookingStatus {
  RESERVED
  CONFIRMED
  WAITLISTED
  EXPIRED
  CANCELLED
  PAYMENT_REJECTED
  TRANSFER_PENDING
  TRANSFERRED
}

enum BookingOccupantRole {
  RIDER
  PILLION
  DRIVER
  PASSENGER
  OTHER
}

enum AccommodationPricingMode {
  INCLUDED
  PER_PERSON
  PER_ROOM
}

enum BookingVehicleMode {
  SAVED_VEHICLE
  RIDE_ONLY_DETAILS
  PRIVATE_VEHICLE
  NO_VEHICLE
}

enum BookingPaymentMethod {
  UPI
  BANK_TRANSFER
  CASH
}

enum BookingPaymentPurpose {
  CONFIRMATION_DEPOSIT
  BALANCE
  FULL_PAYMENT
  OTHER
}

enum BookingPaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
}

enum RideDisruptionType {
  POSTPONEMENT
  CANCELLATION
}

enum RideDisruptionStatus {
  ACTIVE
  RESOLVED
}

enum BookingRefundStatus {
  REVIEW_REQUIRED
  PENDING
  PARTIALLY_REFUNDED
  REFUNDED
}

enum NotificationEventType {
  BOOKING_RESERVED
  BOOKING_WAITLISTED
  BOOKING_PAYMENT_SUBMITTED
  BOOKING_PAYMENT_CONFIRMED
  BOOKING_PAYMENT_REJECTED
  BOOKING_RESERVATION_EXPIRED
  BOOKING_WAITLIST_PROMOTED
  RIDE_POSTPONED
  RIDE_CANCELLED
  RIDE_ANNOUNCEMENT
  RIDE_START_REMINDER
  BOOKING_PAYMENT_REMINDER
}

enum RideAnnouncementUrgency {
  NORMAL
  IMPORTANT
  CRITICAL
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

enum EmailDeliveryStatus {
  NOT_TRACKED
  ACCEPTED
  DELIVERED
  DELAYED
  BOUNCED
  COMPLAINED
  REJECTED
  SUPPRESSED
}

model Community {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                   String          @unique @db.VarChar(80)
  name                   String          @db.VarChar(160)
  shortName              String          @map("short_name") @db.VarChar(12)
  tagline                String          @db.VarChar(240)
  description            String          @db.Text
  foundedYear            Int?            @map("founded_year") @db.SmallInt
  memberCount            Int             @default(0) @map("member_count")
  completedRides         Int             @default(0) @map("completed_rides")
  status                 CommunityStatus @default(DRAFT)
  accentColor            String          @map("accent_color") @db.VarChar(16)
  heroGradient           String          @map("hero_gradient") @db.Text
  specialties            String[]        @default([])
  websiteUrl             String?         @map("website_url") @db.VarChar(500)
  instagramUrl           String?         @map("instagram_url") @db.VarChar(500)
  whatsappUrl            String?         @map("whatsapp_url") @db.VarChar(500)
  newcomerDisplayEnabled Boolean         @default(false) @map("newcomer_display_enabled")
  awardsDisplayEnabled   Boolean         @default(false) @map("awards_display_enabled")
  logoAssetId            String?         @unique @map("logo_asset_id") @db.Uuid
  coverAssetId           String?         @unique @map("cover_asset_id") @db.Uuid
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  locations            CommunityLocation[]
  visibility           CommunityVisibility?
  paymentSettings      CommunityPaymentSettings?
  rides                Ride[]
  memberships          CommunityMembership[]
  invitations          CommunityInvitation[]
  joinLinks            CommunityJoinLink[]
  auditEvents          CommunityAuditEvent[]
  ridePolicyTemplates  CommunityRidePolicyTemplate[]
  rideStaffAssignments RideStaffAssignment[]
  bookings             RideBooking[]
  notificationEvents   NotificationOutboxEvent[]
  notificationInboxItems NotificationInboxItem[]
  disruptions          RideDisruption[]
  bookingRefunds       BookingRefund[]
  embedOrigins         CommunityEmbedOrigin[]
  mediaAssets          MediaAsset[]                  @relation("CommunityMedia")
  logoAsset            MediaAsset?                   @relation("CommunityLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
  coverAsset           MediaAsset?                   @relation("CommunityCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  @@map("communities")
}

model CommunityLocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  city        String   @db.VarChar(120)
  state       String?  @db.VarChar(120)
  countryCode String   @default("IN") @map("country_code") @db.Char(2)
  isHome      Boolean  @default(false) @map("is_home")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, city, state, countryCode])
  @@index([city])
  @@map("community_locations")
}

model CommunityVisibility {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId           String              @unique @map("community_id") @db.Uuid
  directoryVisibility   DirectoryVisibility @default(UNLISTED) @map("directory_visibility")
  guildHallAccess       GuildHallAccess     @default(INVITE_ONLY) @map("guild_hall_access")
  searchIndexing        SearchIndexing      @default(NOINDEX) @map("search_indexing")
  defaultRideVisibility RideVisibility      @default(INVITE_ONLY) @map("default_ride_visibility")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("community_visibility_settings")
}

model CommunityEmbedOrigin {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  origin      String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, origin])
  @@map("community_embed_origins")
}

model CommunityPaymentSettings {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId             String   @unique @map("community_id") @db.Uuid
  upiEnabled              Boolean  @default(false) @map("upi_enabled")
  upiVpa                  String?  @map("upi_vpa") @db.VarChar(130)
  upiPayeeName            String?  @map("upi_payee_name") @db.VarChar(120)
  participantInstructions String?  @map("participant_instructions") @db.Text
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("community_payment_settings")
}

model Ride {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId              String         @map("community_id") @db.Uuid
  slug                     String         @unique @db.VarChar(100)
  title                    String         @db.VarChar(180)
  summary                  String         @db.Text
  description              String         @default("") @db.Text
  originCity               String         @map("origin_city") @db.VarChar(120)
  destination              String         @db.VarChar(160)
  startsAt                 DateTime       @map("starts_at") @db.Timestamptz(3)
  endsAt                   DateTime       @map("ends_at") @db.Timestamptz(3)
  pricePaise               Int            @map("price_paise")
  confirmationDepositPaise Int            @default(0) @map("confirmation_deposit_paise")
  balanceDueAt             DateTime?      @map("balance_due_at") @db.Timestamptz(3)
  registrationClosesAt     DateTime?      @map("registration_closes_at") @db.Timestamptz(3)
  totalSlots               Int            @map("total_slots")
  waitlistCapacity         Int            @default(0) @map("buffer_slots")
  bookedSlots              Int            @default(0) @map("booked_slots")
  vehicleType              VehicleType    @default(BIKE) @map("vehicle_type")
  vehicleRequirements      String         @default("") @map("vehicle_requirements") @db.Text
  difficulty               RideDifficulty
  status                   RideStatus     @default(DRAFT)
  visibility               RideVisibility @default(PUBLIC)
  featured                 Boolean        @default(false)
  heroGradient             String         @map("hero_gradient") @db.Text
  distanceKm               Int            @map("distance_km")
  coverAssetId             String?        @unique @map("cover_asset_id") @db.Uuid
  whatsappInviteEncrypted  String?        @map("whatsapp_invite_encrypted") @db.Text
  whatsappInviteUpdatedAt  DateTime?      @map("whatsapp_invite_updated_at") @db.Timestamptz(3)
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  community        Community             @relation(fields: [communityId], references: [id], onDelete: Restrict)
  staffAssignments RideStaffAssignment[]
  origins          RideOrigin[]
  itineraryDays    RideItineraryDay[]
  accommodations   RideAccommodation[]
  packageItems     RidePackageItem[]
  policies         RidePolicy[]
  mediaAssets      MediaAsset[]          @relation("RideMedia")
  coverAsset       MediaAsset?           @relation("RideCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  aiGenerations    RideAiGeneration[]
  announcements    RideAnnouncement[]
  bookings         RideBooking[]
  disruptions      RideDisruption[]

  @@unique([communityId, slug])
  @@unique([id, communityId])
  @@index([communityId, status, startsAt])
  @@index([originCity, status, startsAt])
  @@index([featured, status, startsAt])
  @@map("rides")
}

model RideOrigin {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId         String   @map("ride_id") @db.Uuid
  city           String   @db.VarChar(120)
  meetingPoint   String   @map("meeting_point") @db.VarChar(240)
  departureAt    DateTime @map("departure_at") @db.Timestamptz(3)
  capacity       Int?
  bufferCapacity Int      @default(0) @map("buffer_capacity")
  mergePoint     String?  @map("merge_point") @db.VarChar(240)
  routeSummary   String?  @map("route_summary") @db.Text
  sortOrder      Int      @default(0) @map("sort_order")

  ride             Ride                  @relation(fields: [rideId], references: [id], onDelete: Cascade)
  staffAssignments RideStaffAssignment[]
  bookings         RideBooking[]

  @@index([rideId, sortOrder])
  @@map("ride_origins")
}

model CommunityRidePolicyTemplate {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String         @map("community_id") @db.Uuid
  type        RidePolicyType
  title       String         @db.VarChar(180)
  content     String         @db.Text
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, type])
  @@map("community_ride_policy_templates")
}

model RideItineraryDay {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId      String    @map("ride_id") @db.Uuid
  dayNumber   Int       @map("day_number")
  sortOrder   Int       @default(0) @map("sort_order")
  date        DateTime  @db.Date
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(3)
  title       String    @db.VarChar(180)
  summary     String    @db.Text

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@unique([rideId, sortOrder])
  @@map("ride_itinerary_days")
}

model RideAccommodationOption {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accommodationId String                   @map("accommodation_id") @db.Uuid
  name            String                   @db.VarChar(160)
  description     String?                  @db.Text
  pricingMode     AccommodationPricingMode @map("pricing_mode")
  pricePaise      Int                      @default(0) @map("price_paise")
  maxOccupancy    Int                      @default(2) @map("max_occupancy") @db.SmallInt
  availableRooms  Int?                     @map("available_rooms") @db.SmallInt
  sortOrder       Int                      @default(0) @map("sort_order")
  active          Boolean                  @default(true)

  accommodation RideAccommodation               @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  selections    BookingAccommodationSelection[]

  @@unique([accommodationId, name])
  @@index([accommodationId, sortOrder])
  @@map("ride_accommodation_options")
}

model RideAccommodation {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId                  String   @map("ride_id") @db.Uuid
  propertyName            String   @map("property_name") @db.VarChar(180)
  locality                String   @db.VarChar(180)
  checkInAt               DateTime @map("check_in_at") @db.Timestamptz(3)
  checkOutAt              DateTime @map("check_out_at") @db.Timestamptz(3)
  roomSummary             String   @map("room_summary") @db.Text
  amenities               String[] @default([])
  participantNote         String?  @map("participant_note") @db.Text
  exactLocationRestricted Boolean  @default(true) @map("exact_location_restricted")

  ride    Ride                      @relation(fields: [rideId], references: [id], onDelete: Cascade)
  options RideAccommodationOption[]

  @@index([rideId, checkInAt])
  @@map("ride_accommodations")
}

model RidePackageItem {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId      String              @map("ride_id") @db.Uuid
  type        RidePackageItemType
  dayNumber   Int?                @map("day_number")
  title       String              @db.VarChar(180)
  description String?             @db.Text
  pricePaise  Int?                @map("price_paise")
  sortOrder   Int                 @default(0) @map("sort_order")

  ride          Ride           @relation(fields: [rideId], references: [id], onDelete: Cascade)
  bookingAddOns BookingAddOn[]

  @@index([rideId, type, sortOrder])
  @@map("ride_package_items")
}

model RidePolicy {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId    String         @map("ride_id") @db.Uuid
  type      RidePolicyType
  title     String         @db.VarChar(180)
  content   String         @db.Text
  version   Int            @default(1)
  sortOrder Int            @default(0) @map("sort_order")

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@unique([rideId, type, version])
  @@map("ride_policies")
}

model User {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayName String     @map("display_name") @db.VarChar(120)
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  contacts                    UserContact[]
  sessions                    Session[]
  platformRoles               PlatformRoleAssignment[]
  communityMemberships        CommunityMembership[]
  rideStaffAssignments        RideStaffAssignment[]
  profile                     ParticipantProfile?
  vehicles                    Vehicle[]
  externalIdentities          ExternalIdentity[]
  phoneVerificationChallenges PhoneVerificationChallenge[]
  uploadedMedia               MediaAsset[]                 @relation("MediaUploader")
  sentCommunityInvitations    CommunityInvitation[]        @relation("CommunityInvitationSender")
  createdCommunityJoinLinks   CommunityJoinLink[]          @relation("CommunityJoinLinkCreator")
  communityAuditEvents        CommunityAuditEvent[]        @relation("CommunityAuditActor")
  rideAiGenerations           RideAiGeneration[]
  rideAnnouncements           RideAnnouncement[]
  rideAnnouncementAcknowledgements RideAnnouncementAcknowledgement[]
  rideBookings                RideBooking[]
  bookingParticipants         BookingParticipant[]
  reviewedBookingPayments     BookingPayment[]             @relation("BookingPaymentReviewer")
  notificationEvents          NotificationOutboxEvent[]
  notificationInboxItems      NotificationInboxItem[]
  notificationPreference      UserNotificationPreference?
  createdRideDisruptions      RideDisruption[]             @relation("RideDisruptionCreator")
  reviewedBookingRefunds      BookingRefund[]              @relation("BookingRefundReviewer")

  @@map("users")
}

model ExternalIdentity {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  provider        ExternalIdentityProvider
  providerSubject String                   @map("provider_subject") @db.VarChar(255)
  emailAtLink     String                   @map("email_at_link") @db.VarChar(320)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
  @@map("external_identities")
}

model ParticipantProfile {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String                     @unique @map("user_id") @db.Uuid
  homeCity                  String?                    @map("home_city") @db.VarChar(120)
  homeState                 String?                    @map("home_state") @db.VarChar(120)
  countryCode               String                     @default("IN") @map("country_code") @db.Char(2)
  operationalPhone          String?                    @map("operational_phone") @db.VarChar(24)
  phoneVerifiedAt           DateTime?                  @map("phone_verified_at") @db.Timestamptz(3)
  phoneVerificationProvider PhoneVerificationProvider? @map("phone_verification_provider")
  avatarAssetId             String?                    @unique @map("avatar_asset_id") @db.Uuid
  emergencyContactName      String?                    @map("emergency_contact_name") @db.VarChar(120)
  emergencyContactPhone     String?                    @map("emergency_contact_phone") @db.VarChar(24)
  emergencyRelationship     String?                    @map("emergency_relationship") @db.VarChar(80)
  dietaryPreference         String?                    @map("dietary_preference") @db.VarChar(120)
  bloodGroup                String?                    @map("blood_group") @db.VarChar(20)
  accessibilityNotes        String?                    @map("accessibility_notes") @db.Text
  termsAcceptedAt           DateTime?                  @map("terms_accepted_at") @db.Timestamptz(3)
  privacyAcceptedAt         DateTime?                  @map("privacy_accepted_at") @db.Timestamptz(3)
  onboardingCompletedAt     DateTime?                  @map("onboarding_completed_at") @db.Timestamptz(3)
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarAsset MediaAsset? @relation("ParticipantAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)

  @@index([homeCity])
  @@map("participant_profiles")
}

model MediaAsset {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploaderUserId String       @map("uploader_user_id") @db.Uuid
  communityId    String?      @map("community_id") @db.Uuid
  rideId         String?      @map("ride_id") @db.Uuid
  purpose        MediaPurpose
  access         MediaAccess  @default(PUBLIC)
  provider       String       @default("CLOUDINARY") @db.VarChar(32)
  publicId       String       @unique @map("public_id") @db.VarChar(500)
  version        Int
  resourceType   String       @default("image") @map("resource_type") @db.VarChar(32)
  deliveryType   String       @default("upload") @map("delivery_type") @db.VarChar(32)
  format         String       @db.VarChar(24)
  width          Int?
  height         Int?
  bytes          Int?
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  uploader        User                @relation("MediaUploader", fields: [uploaderUserId], references: [id], onDelete: Restrict)
  community       Community?          @relation("CommunityMedia", fields: [communityId], references: [id], onDelete: Cascade)
  avatarFor       ParticipantProfile? @relation("ParticipantAvatar")
  logoFor         Community?          @relation("CommunityLogo")
  coverFor        Community?          @relation("CommunityCover")
  ride            Ride?               @relation("RideMedia", fields: [rideId], references: [id], onDelete: Cascade)
  rideCoverFor    Ride?               @relation("RideCover")
  paymentProofFor BookingPayment?     @relation("BookingPaymentProof")

  @@index([communityId, purpose, sortOrder])
  @@index([rideId, purpose, sortOrder])
  @@index([uploaderUserId, purpose])
  @@map("media_assets")
}

model PhoneVerificationChallenge {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                    @map("user_id") @db.Uuid
  provider        PhoneVerificationProvider @default(FIREBASE)
  status          PhoneVerificationStatus   @default(PENDING)
  normalizedPhone String                    @map("normalized_phone") @db.VarChar(24)
  tokenHash       String                    @unique @map("token_hash") @db.VarChar(128)
  requestIpHash   String?                   @map("request_ip_hash") @db.VarChar(128)
  attemptCount    Int                       @default(0) @map("attempt_count")
  maxAttempts     Int                       @default(5) @map("max_attempts")
  expiresAt       DateTime                  @map("expires_at") @db.Timestamptz(3)
  consumedAt      DateTime?                 @map("consumed_at") @db.Timestamptz(3)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([normalizedPhone, createdAt])
  @@index([expiresAt])
  @@map("phone_verification_challenges")
}

model Vehicle {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
